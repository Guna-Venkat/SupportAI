# Normalise line endings to LF in the repository.
* text=auto eol=lf

# Python files
*.py text eol=lf
*.pyi text eol=lf

# Config files
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Notebooks (JSON-based, keep LF)
*.ipynb text eol=lf

# Shell scripts
*.sh text eol=lf
Makefile text eol=lf

# Docs
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf

# Binary files – no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pt binary
*.pkl binary
*.onnx binary
