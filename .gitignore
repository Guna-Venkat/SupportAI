# =========================================================
# .gitignore – SupportAI
# Covers: Python, Jupyter, Windows, macOS, DVC, MLflow,
#         Docker, VS Code, PyCharm, and data artefacts.
# =========================================================

# -------------------------------------------------------
# Python
# -------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
develop-eggs/
downloads/
eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.manifest
*.spec
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/
.env
*.env

# -------------------------------------------------------
# Type checkers / linters
# -------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# -------------------------------------------------------
# Testing / coverage
# -------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
nosetests.xml
*.cover
.hypothesis/

# -------------------------------------------------------
# Jupyter Notebooks
# -------------------------------------------------------
.ipynb_checkpoints/
*/.ipynb_checkpoints/
profile_default/
ipython_config.py

# -------------------------------------------------------
# DVC
# -------------------------------------------------------
/data/
/outputs/

# Keep directory stubs and .gitkeep files
!data/.gitkeep
!outputs/.gitkeep
!outputs/models/.gitkeep
!outputs/metrics/.gitkeep
!outputs/figures/.gitkeep
!outputs/checkpoints/.gitkeep

# DVC cache and tmp
.dvc/cache/
.dvc/tmp/

# -------------------------------------------------------
# MLflow
# -------------------------------------------------------
/mlruns/
/outputs/mlruns/
mlflow.db

# -------------------------------------------------------
# Logs
# -------------------------------------------------------
/logs/
*.log
*.log.*

# -------------------------------------------------------
# Secrets / credentials
# -------------------------------------------------------
.env.local
.env.*.local
secrets.yaml
secrets/
*.pem
*.key
*.crt

# -------------------------------------------------------
# Editors
# -------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# -------------------------------------------------------
# OS files
# -------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk
*.cab
*.msi
*.msix
*.msm
*.msp

# -------------------------------------------------------
# Docker
# -------------------------------------------------------
*.dockerignore

# -------------------------------------------------------
# Miscellaneous
# -------------------------------------------------------
*.bak
*.swp
*.tmp
*.orig
*.rej
.benchmarks/
